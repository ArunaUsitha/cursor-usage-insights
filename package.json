{
  "name": "cursor-usage-dashboard",
  "displayName": "Cursor Usage Dashboard",
  "description": "Track your remaining Cursor requests and spend: status bar quota gauge, cost dashboard, cache savings, model breakdown, cost simulator.",
  "version": "0.3.3",
  "publisher": "iair0007",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/iair0007/cursor-usage"
  },
  "homepage": "https://github.com/iair0007/cursor-usage#readme",
  "bugs": {
    "url": "https://github.com/iair0007/cursor-usage/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "cursor",
    "cursor ide",
    "usage",
    "tokens",
    "token usage",
    "cost",
    "cost tracker",
    "spend",
    "spending",
    "billing",
    "budget",
    "quota",
    "requests",
    "analytics",
    "dashboard",
    "pricing",
    "cache savings",
    "status bar"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cursorUsage.openDashboard",
        "title": "Cursor Usage: Open Dashboard"
      },
      {
        "command": "cursorUsage.refresh",
        "title": "Cursor Usage: Refresh"
      },
      {
        "command": "cursorUsage.setSessionToken",
        "title": "Cursor Usage: Set Session Token Manually"
      },
      {
        "command": "cursorUsage.setAdminApiKey",
        "title": "Cursor Usage: Set Team Admin API Key"
      },
      {
        "command": "cursorUsage.clearStoredCredentials",
        "title": "Cursor Usage: Clear Stored Credentials"
      },
      {
        "command": "cursorUsage.showLogs",
        "title": "Cursor Usage: Show Logs"
      }
    ],
    "configuration": {
      "title": "Cursor Usage Dashboard",
      "properties": {
        "cursorUsage.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show current period token cost in the status bar."
        },
        "cursorUsage.statusBar.costMode": {
          "type": "string",
          "enum": [
            "value",
            "billed"
          ],
          "enumDescriptions": [
            "API-equivalent value of your tokens, even on plans/requests where nothing is actually charged.",
            "What you were actually billed (0 on free plans and for included/errored requests)."
          ],
          "default": "value",
          "description": "Whether the status bar shows the what-if token value or the actually billed cost."
        },
        "cursorUsage.refreshIntervalMinutes": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "description": "How often the status bar refreshes usage data (minutes)."
        },
        "cursorUsage.statusBar.periodDays": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "maximum": 90,
          "description": "How many days back the status bar cost figure covers."
        },
        "cursorUsage.statusBar.warnAtPercent": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 99,
          "description": "Highlight the status bar (warning color) once this % of your plan's included requests are used."
        },
        "cursorUsage.statusBar.criticalAtPercent": {
          "type": "number",
          "default": 95,
          "minimum": 1,
          "maximum": 200,
          "description": "Highlight the status bar (error color) once this % of your plan's included requests are used."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc --noEmit && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "node test/run-tests.mjs",
    "package": "npm run compile && vsce package"
  },
  "dependencies": {
    "chart.js": "^4.4.1",
    "sql.js": "^1.10.2"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
